{
  "dependencies": {
    "dayjs": "^1.11.19",
    "md5": "^2.3.0"
  },
  "devDependencies": {
    "@types/md5": "^2.3.6",
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "web:dev": "pnpm --filter @ai-en/web dev",
    "web-vue:dev": "pnpm --filter @ai-en/web-vue dev",
    "server:dev": "pnpm --filter @ai-en/server start:dev",
    "ai:dev": "pnpm --filter @ai-en/server start:dev ai",
    "dev": "concurrently \"pnpm web-vue:dev\" \"pnpm server:dev\" \"pnpm ai:dev\""
  }
}
